# OS
.DS_Store
Thumbs.db
desktop.ini

# DAW / audio (adjust for your DAW)
*.peak
*.reapeaks
*.asd
*.cfa
*.pek

# Bounces / exports can be huge — uncomment to ignore, or track selectively
# bounces/
# exports/

# Env / secrets
.env
.env.*

# Patent / IP drafts
patent_work/

# Cloudflare Wrangler local state
.wrangler/

# Local Codex worktrees
.claude/worktrees/

# OVE deploy files — must never be re-added
oak-valley-estates-inspect/

# Python
__pycache__/
*.py[cod]
*$py.class

# Local app logs (regenerated at runtime)
console_debug.log

# Generated stem WAVs (see software/generate_band_stems.py)
software/band_stems/*.wav

# Generated CAD exports
*.step

# Test audio loops
software/loops/*.wav

# Spreadsheet exports
*.xlsx
